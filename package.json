{
   "name": "uglychristmassweater",
   "version": "1.0.0",
   "description": "",
   "main": "modules/js/Game.js",
   "scripts": {
      "build:ts": "rollup -c",
      "build:scss": "sass --no-source-map src/scss/Game.scss uglychristmassweater.css",
      "build:sprites": "node scripts/build-sprites.mjs && node scripts/build-secondary-sprites.mjs",
      "build:icons": "node scripts/build-icons.mjs",
      "clean:remote": "node scripts/clean-remote.mjs",
      "deploy": "node scripts/deploy.mjs",
      "ship": "npm run build && npm run deploy -- --yes",
      "watch:ts": "rollup -c -w",
      "watch:scss": "sass --watch src/scss/Game.scss uglychristmassweater.css",
      "watch": "npm run watch:ts & npm run watch:scss",
      "build": "npm run build:ts && npm run build:scss"
   },
   "author": "yourname",
   "license": "MIT",
   "devDependencies": {
      "@rollup/plugin-typescript": "^12.3.0",
      "rollup": "^4.53.3",
      "sass": "^1.71.0",
      "sharp": "^0.35.3",
      "ssh2-sftp-client": "^12.1.1",
      "tslib": "^2.8.1",
      "typescript": "^6.0.3"
   }
}
